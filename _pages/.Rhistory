# ============================================================
# Final Grade Calculation - Political Economy (Spring 2026)
# ECON 3216 / POLS 3216
#
# Weights:
#   Final Policy Memo                                40%
#   Four short memos (10% each)                      40%
#   Participation bucket                             20%
#     - within bucket: 20% Participation column
#                      80% Discussion Leader column
#   ExtraCredit                                      added as raw points
# ============================================================
library(tidyverse)
# --- 1. File paths --------------------------------------------------
econ_path <- "2026-05-16T1219_Grades-2026_SPRING_ECON3216EXP.csv"
pols_path <- "2026-05-16T1219_Grades-2026_SPRING_POLS3216EXP.csv"
# --- 2. Read and clean ----------------------------------------------
strip_canvas_ids <- function(df) {
df %>% rename_with(~ str_remove(.x, "\\s*\\(\\d+\\)\\s*$"))
}
grades <- bind_rows(
read_csv(econ_path, show_col_types = FALSE) %>% strip_canvas_ids(),
read_csv(pols_path, show_col_types = FALSE) %>% strip_canvas_ids()
)
grade_cols <- c("Final Policy Memo", "Memo 1", "Memo 2", "Memo 3", "Memo 4",
"Participation", "Discussion Leader", "ExtraCredit")
grades <- grades %>%
mutate(across(all_of(grade_cols), ~ replace_na(as.numeric(.x), 0)))
# --- 3. Letter grade function (per syllabus) ------------------------
assign_letter <- function(score) {
case_when(
score >= 94 ~ "A",
score >= 90 ~ "A-",
score >= 87 ~ "B+",
score >= 83 ~ "B",
score >= 80 ~ "B-",
score >= 77 ~ "C+",
score >= 73 ~ "C",
score >= 70 ~ "C-",
score >= 67 ~ "D+",
score >= 60 ~ "D",
TRUE        ~ "F"
)
}
# --- 4. Compute final grades ----------------------------------------
final_grades <- grades %>%
mutate(
memo_avg      = (`Memo 1` + `Memo 2` + `Memo 3` + `Memo 4`) / 4,
# Within the 20% participation bucket: 20% Participation + 80% DL
part_combined = 0.20 * Participation + 0.80 * `Discussion Leader`,
final_score   = round(0.40 * `Final Policy Memo` +
0.40 * memo_avg +
0.20 * part_combined +
ExtraCredit, 2),
letter_grade  = assign_letter(final_score),
short_section = str_extract(Section, "ECON3216|POLS3216")
) %>%
select(Student, short_section, final_score, letter_grade,
`Final Policy Memo`, memo_avg,
Participation, `Discussion Leader`, part_combined, ExtraCredit) %>%
arrange(short_section, Student)
# --- 5. Print -------------------------------------------------------
# width = Inf prevents tibble from truncating columns in the console
print(final_grades, n = Inf, width = Inf)
# Distribution by section
final_grades %>%
count(short_section, letter_grade) %>%
pivot_wider(names_from = letter_grade, values_from = n, values_fill = 0) %>%
print()
# --- Optional: just name + final_score + letter ---------------------
# Uncomment for a clean short table:
# final_grades %>%
#   select(short_section, Student, final_score, letter_grade) %>%
#   print(n = Inf)
